# NeuroClassifier — environment variables
# Copy this file to .env and fill in production values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neuroclassifier:secret@postgres:5432/neuroclassifier
DATABASE_URL_SYNC=postgresql+psycopg2://neuroclassifier:secret@postgres:5432/neuroclassifier

# ─── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
DATASETS_BUCKET=datasets
MODELS_BUCKET=models

# ─── App ────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=500
